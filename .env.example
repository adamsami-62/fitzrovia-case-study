# Copy to .env and fill in real values. .env is gitignored.

# Anthropic — used by the incentive parser (Step 14).
ANTHROPIC_API_KEY=sk-ant-...

# JWT signing — MUST be a high-entropy random string in production.
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Seeded users. These two credentials get bcrypt-hashed at init_db time.
ADMIN_EMAIL=admin@fitzrovia.test
ADMIN_PASSWORD=change-this-too
VIEWER_EMAIL=viewer@fitzrovia.test
VIEWER_PASSWORD=change-this-too

# CORS — comma-separated list of allowed frontend origins.
ALLOWED_ORIGIN=http://localhost:3000

# SQLite on local disk. Fine for this case study; swap to Postgres for prod.
DATABASE_URL=sqlite:///./backend/data/app.db

ENV=development
